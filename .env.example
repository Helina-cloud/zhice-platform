# 复制本文件为 .env 后填写。切勿将含真实密钥的 .env 提交到版本库。

# ---------- 推荐：对话 + 嵌入均用 OpenAI（同一密钥与网关）----------
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
CHAT_MODEL=gpt-4o-mini

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
# 不设 EMBEDDING_API_KEY / EMBEDDING_API_BASE 时，嵌入会自动共用上面的 OPENAI_API_KEY 与 OPENAI_API_BASE。

# ---------- 可选：嵌入单独走别的 OpenAI 兼容网关时再填 ----------
# EMBEDDING_API_KEY=
# EMBEDDING_API_BASE=https://api.openai.com/v1

# ---------- 可选：本地向量（不想为 embeddings 调用 OpenAI 时）----------
# EMBEDDING_PROVIDER=huggingface
# HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# 需安装: pip install sentence-transformers

# ---------- 可选：对话用 DeepSeek（OpenAI 兼容），嵌入须单独网关或 huggingface ----------
# OPENAI_API_KEY=（DeepSeek 的 sk-）
# OPENAI_API_BASE=https://api.deepseek.com
# CHAT_MODEL=deepseek-chat
# 此时勿把 DeepSeek 密钥当嵌入用；请配 EMBEDDING_API_* 或 EMBEDDING_PROVIDER=huggingface

# Agent 联网搜索：pip install ddgs（推荐）；若无 ddgs 会尝试 duckduckgo-search

# 可选：覆盖默认路径（文档目录与 FAISS 向量库目录）
# DATA_DOCS_DIR=e:\code\zhice-platform\data\docs
# VECTOR_STORE_DIR=e:\code\zhice-platform\data\vector_db

CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVER_K=4

# ---------- HTTPS / 代理（嵌入与对话请求共用 httpx；遇 SSL EOF / ConnectError 时再改）----------
# OPENAI_HTTP_TRUST_ENV=false
# OPENAI_HTTP_VERIFY_SSL=false
# OPENAI_PROXY=http://127.0.0.1:7890

# 增强版：业务指标 API 根地址（示例：http://127.0.0.1:8080）
# ANALYTICS_API_BASE=
# ANALYTICS_TIMEOUT_S=15
